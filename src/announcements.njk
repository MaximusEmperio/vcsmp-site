---
layout: base.njk
title: Announcements
permalink: /announcements/index.html
description: Everything happening on the Virtual Congress SMP, newest first.
---
<h1 class="page-title">Announcements</h1>
<p class="page-sub">newest first</p>

<ul class="stream">
{% for post in collections.posts %}
  <li class="stream-item">
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.excerpt %}<p>{{ post.data.excerpt }}</p>{% endif %}
    <a class="more" href="{{ post.url }}">read more →</a>
  </li>
{% endfor %}
</ul>
